<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The engine dlopens game-code dylibs (our own per-mod libs, and possibly
	     a user-added mod's own client/server lib). Under the hardened runtime,
	     library validation would reject any dylib not signed by our Team ID, so
	     disable it to keep the engine moddable. -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
